{
  "name": "lwdb",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "lwdb — agent-first MySQL workbench: a JSON-native CLI, an MCP server, and a native desktop app over one shared core.",
  "author": "Sibin C Baby",
  "license": "MIT",
  "homepage": "https://github.com/sibincbaby/lwdb#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sibincbaby/lwdb.git"
  },
  "bugs": {
    "url": "https://github.com/sibincbaby/lwdb/issues"
  },
  "keywords": [
    "mysql",
    "database",
    "cli",
    "db-browser",
    "claude-code",
    "ai-agent",
    "mcp",
    "tauri"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "lwdb": "./bin/lwdb.mjs"
  },
  "files": [
    "bin/",
    "server/",
    "dist/",
    "install.mjs",
    ".claude/skills/lwdb/SKILL.md",
    "connections.example.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch --no-warnings=ExperimentalWarning server/index.mjs",
    "dev:web": "vite",
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "start": "node --no-warnings=ExperimentalWarning server/index.mjs",
    "setup": "node install.mjs install",
    "cli": "node bin/lwdb.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "desktop:build": "APPIMAGE_EXTRACT_AND_RUN=1 tauri build",
    "desktop:clean": "rm -rf src-tauri/target/release/bundle",
    "desktop:rebuild": "npm run desktop:clean && npm run desktop:build",
    "release:patch": "node tools/release.mjs patch",
    "release:minor": "node tools/release.mjs minor",
    "release:major": "node tools/release.mjs major",
    "install:full": "node install.mjs install",
    "doctor": "node install.mjs doctor",
    "test": "node --no-warnings=ExperimentalWarning --test --test-reporter=spec \"tests/*.test.mjs\"",
    "test:ci": "node --no-warnings=ExperimentalWarning --test --test-concurrency=1 --test-reporter=spec \"tests/*.test.mjs\"",
    "e2e:diagnose": "node tests/e2e/diagnose-results.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,mjs,vue,json,md,css}\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "mysql2": "^3.11.4"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.18.1",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/language": "^6.10.3",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.1",
    "@tauri-apps/cli": "^2.11.2",
    "@vitejs/plugin-vue": "^5.1.4",
    "codemirror": "^6.0.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.13.0",
    "eslint-plugin-vue": "^9.30.0",
    "playwright": "^1.60.0",
    "prettier": "^3.3.3",
    "vite": "^5.4.10",
    "vue": "^3.5.12"
  },
  "lwDb": {
    "port": 4321,
    "host": "127.0.0.1"
  }
}
