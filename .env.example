# lwdb runtime configuration
# Copy to .env (loaded by your shell/process manager) or set in environment.
# Everything here is optional — lwdb works with sensible defaults out of the box.

# Server bind (the GUI server / daemon)
LW_DB_HOST=127.0.0.1
LW_DB_PORT=4321

# Where the SQLite file lives (connections, snippets, history, preferences).
# Default: ./data/lwdb.sqlite
# LW_DB_SQLITE=/var/lib/lwdb/lwdb.sqlite
# LW_DB_DATA_DIR=./data

# Credential encryption key (32 bytes). Default: a 0600 file at ~/.lwdb/key,
# generated on first use. Override with an inline base64 key or a custom path.
# LW_DB_KEY=<base64 of 32 bytes>
# LW_DB_KEY_FILE=/path/to/key

# Optional API token. Unset (default) = no auth, for the localhost-only model.
# Set it ONLY if you bind the server beyond 127.0.0.1 — then every /api request
# must present it (Authorization: Bearer <token>, or ?token=<token> for a browser
# first-load). The CLI/MCP read it from this same env var automatically.
# LW_DB_TOKEN=<a long random string>

# Per-query timeout in ms (default 30s)
# LW_DB_QUERY_TIMEOUT_MS=30000

# Log level: debug | info | warn | error | silent
# LW_DB_LOG_LEVEL=info

# Legacy: directory of dbconf-style *.txt files to import from (see
# tools/dbconfs-to-json.mjs). Not needed for normal use — connections live in
# the SQLite store via `lwdb conn-add` / `lwdb import`.
# LW_DB_CONFS_DIR=/path/to/legacy/dbconfs
